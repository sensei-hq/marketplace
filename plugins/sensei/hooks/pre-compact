#!/usr/bin/env bash
set -euo pipefail

source "$(dirname "$0")/_lib.sh"

PROJECT_ROOT="${CLAUDE_PROJECT_ROOT:-${PWD}}"

# Forward telemetry first so the event reaches the daemon even if the
# context-building below fails.
read_stdin_payload
send_telemetry "$PAYLOAD"

# ── Read rules ──────────────────────────────────────────────────────────
RULES_FILE="${PROJECT_ROOT}/.sensei/rules.md"
RULES=""
if [ -f "$RULES_FILE" ]; then
  RULES=$(head -60 "$RULES_FILE")
fi

# ── Mindsets (shipped as subagents) ──────────────────────────────────────────
MINDSETS_SUMMARY="Core three in sequence: Analyst → Developer → Acceptance Tester; specialists by domain. Each is a subagent — invoke via /sensei:agent."

# ── Read workflow state ──────────────────────────────────────────────────────
STATE_FILE="${PROJECT_ROOT}/.sensei/state.yaml"
STATE=""
if [ -f "$STATE_FILE" ]; then
  STATE=$(cat "$STATE_FILE")
fi

# ── Build context ────────────────────────────────────────────────────────────
CONTEXT="<sensei-refocus>
## Workflow state
${STATE:-No active workflow state.}

## Guardrails
${RULES:-No project rules found. Run /sensei:rules to create.}

## Mindsets
${MINDSETS_SUMMARY:-Mindsets not loaded.}

## Tools
Prefer sensei MCP tools over grep/sed:
- search() for symbol lookup
- get_callers()/get_callees() for dependencies
- get_lib_docs() for library documentation

Run /sensei:session refocus for full orientation after compaction.
</sensei-refocus>"

ESCAPED=$(escape_for_json "$CONTEXT")

cat <<EOF
{
  "additional_context": "${ESCAPED}"
}
EOF
exit 0
